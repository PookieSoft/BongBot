{
    "name": "bongbot",
    "version": "0.1.0",
    "description": "Bong Bot Slash Command Alpha",
    "main": "./dist/index.js",
    "type": "module",
    "scripts": {
        "build": "node esbuild.config.mjs --minify",
        "dev": "docker build . -t bongbot && docker run --rm --env-file .env --volume ./data:/app/data --volume ./logs:/app/logs bongbot",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --json --coverage --outputFile=report.json --passWithNoTests --silent"
    },
    "dependencies": {
        "@pookiesoft/bongbot-core": "^1.6.12",
        "@pookiesoft/bongbot-ptero": "^1.4.6",
        "@pookiesoft/bongbot-quote": "^2.1.16"
    },
    "devDependencies": {
        "@google/generative-ai": "^0.24.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/jest": "^30.0.0",
        "@types/node-schedule": "^2.1.8",
        "better-sqlite3": "^12.9.0",
        "cross-env": "^10.1.0",
        "discord.js": "^14.26.4",
        "esbuild": "^0.28.0",
        "jest": "^30.3.0",
        "jest-junit": "^17.0.0",
        "msw": "^2.14.2",
        "node-schedule": "^2.1.1",
        "prettier": "^3.8.3",
        "source-map-support": "^0.5.21",
        "ts-jest": "^29.4.9",
        "ts-jest-resolver": "^2.0.1",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
}
